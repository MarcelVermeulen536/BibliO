# Chemin vers la base SQLite locale, lu par la CLI Prisma (migrate / generate).
# file: = protocole SQLite (fichier local) ; ./dev.db est relatif au dossier prisma/.
# Remarque : normalement .env est ignore par git, mais ce fichier ne contient
# qu'un chemin local (aucun secret) et est commite pour que le projet se lance directement.
DATABASE_URL="file:./dev.db"
